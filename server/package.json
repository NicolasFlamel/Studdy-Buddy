{
  "name": "@studdy-buddy/server",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec tsx src/server.ts",
    "div:log": "nodemon --exec tsx src/server.ts | tee app.log",
    "seed": "ts-node src/seeds/seed.ts",
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 0",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "docker:up": "docker compose -p studdy-buddy up -d",
    "docker:down": "docker compose -p studdy-buddy down"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@studdy-buddy/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "1.0.0-beta.22",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.19.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "1.0.0-beta.9-e89174b",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
