{
  "name": "@studdy-buddy/root",
  "version": "1.0.0",
  "description": "This is a group project created using Handlebars, CSS, and APIs. The frontend also uses Bootstrap for styling. Studdy Buddy is an application that pairs users looking to partner with a peer to work through a selected course topic, based on how they match up via a self ranking system",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "start": "pnpm --filter server start",
    "dev": "concurrently --names client,server -c green,blue \"pnpm:dev:client\" \"pnpm:dev:server\"",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "lint": "pnpm -r --parallel lint",
    "format": "prettier --write ."
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AliPaia/Studdy-Buddy.git"
  },
  "bugs": {
    "url": "https://github.com/AliPaia/Studdy-Buddy/issues"
  },
  "homepage": "https://github.com/AliPaia/Studdy-Buddy#readme"
}
